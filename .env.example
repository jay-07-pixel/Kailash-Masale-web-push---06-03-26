# Copy to .env and fill with values from Firebase Console → Project settings → Your apps.
# Never commit .env. For deploy (Vercel/Netlify), set these as environment variables in the dashboard.

VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_WITH_YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=REPLACE_WITH_YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_WITH_YOUR_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_YOUR_APP_ID

# Optional: comma-separated emails that may edit TA/DA overrides on Expenditure. If empty, any signed-in user can.
# VITE_EXPENDITURE_ADMIN_EMAILS=admin@example.com
